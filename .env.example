SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua-chave-anon-aqui

# Opcionais — para IA executar SQL diretamente no banco
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key
SUPABASE_PAT=seu-personal-access-token

# Google OAuth (opcional — para login com Google)
GOOGLE_CLIENT_ID=seu-google-client-id

# Multi-tenant: store padrão para desenvolvimento local (ID da Israelita = 1)
DEFAULT_STORE_ID=1
