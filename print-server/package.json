{
  "name": "queropizza-print-server",
  "version": "1.0.0",
  "description": "Servidor de impressão para Israelita Pizzas",
  "author": "Israelita Pizzas",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win"
  },
  "dependencies": {
    "express": "^4.18.2",
    "iconv-lite": "^0.7.3"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.israelita.print-server",
    "productName": "QueroPizza Print Server",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "server.js",
      "settings.html",
      "settings.js",
      "settings.css",
      "package.json",
      "RawPrinter.exe",
      "tray-icon.png"
    ],
    "extraResources": [
      {
        "from": "RawPrinter.exe",
        "to": "RawPrinter.exe"
      }
    ],
    "win": {
      "target": "nsis",
      "artifactName": "${productName}-${version}-Setup.${ext}",
      "sign": false
    },
    "nsis": {
      "perMachine": false,
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "QueroPizza Print Server",
      "uninstallDisplayName": "QueroPizza Print Server"
    }
  }
}
